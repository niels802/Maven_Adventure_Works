-- 10-day Rolling Revenue
-- Description: Calculates total revenue over the last 10 days based on the selected date
-- Use case: Useful for short-term trend analysis
-- Depends on: Date table, Revenue measure

10-day Rolling Revenue = 
CALCULATE(
    [Total Revenue],
    DATESINPERIOD(
        'Calendar Lookup'[Date],
        MAX(
            'Calendar Lookup'[Date]
        ),
        -10,
        DAY
    )
)
